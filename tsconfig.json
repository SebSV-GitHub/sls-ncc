{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "nodenext",
		"allowJs": true, // TODO: Remove this, it's just used as demonstration for module typing
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"declaration": true,
		"paths": {
			"@/": ["./src/*"]
		},
		"typeRoots": ["./node_modules/@types", "./src/types"]
	},
	"ts-node": {
		"compilerOptions": {
			"module": "CommonJS"
		},
		"moduleTypes": {
			"gulpfile.ts": "cjs"
		}
	},
	"include": ["src/**/*"]
}
